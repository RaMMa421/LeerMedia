<!-- =============================================
     SZENE 2: REZEPTIONSDIALOG – ANIMIERTER WARTEBEREICH
     ============================================= -->
<section id="scene-2" class="scene">
  <div class="progress-bar" id="progress-2"></div>
  <div class="scene-inner">
    <h2 class="scene-title">👩‍💼 An der Rezeption</h2>
    <p class="scene-subtitle">Wähle die richtige Antwort!</p>

    <div class="reception-scene">

      <!-- ── Illustrated clinic reception room ── -->
      <div class="clinic-room">
        <!-- Background decorations -->
        <div class="room-window"></div>
        <div class="room-sun"></div>
        <div class="wall-cross">🏥</div>
