/* ─── Fisher-Yates-Mischen ─── */
function shuffleArray(arr) {
  for (let i = arr.length - 1; i > 0; i--) {
    const j = randInt(0, i);
    [arr[i], arr[j]] = [arr[j], arr[i]];
  }
}

/* ─── Reorder neu mischen ─── */
function reshuffleReorder() {
  shuffleArray(currentOrder);
  renderReorder();
  hideFeedback('4');
  document.getElementById('btn-continue-4').classList.add('hidden');
}

/* ─── Reorder-Blöcke rendern ─── */
function renderReorder() {
  const container = document.getElementById('reorder-list');
  container.innerHTML = '';

  currentOrder.forEach((origIdx, displayIdx) => {
    const line = activeIllness.dialogue[origIdx];
    const div  = document.createElement('div');
    div.className = 'reorder-block';
    div.draggable = true;
    div.dataset.index = displayIdx;

    const speakerLabel = line.speaker === 'arzt' ? '👨‍⚕️ Arzt' : '🧑 Patient';
    div.innerHTML = `
      <span class="drag-handle">⠿</span>
      <span class="block-num">${displayIdx + 1}</span>
      <div style="flex:1;">
        <div class="block-speaker-badge">${speakerLabel}</div>
        <div style="font-weight:700;font-size:0.93rem;">${line.text}</div>
      </div>
    `;

    div.addEventListener('dragstart', onDragStart);
    div.addEventListener('dragover',  onDragOver);
    div.addEventListener('drop',      onDrop);
    div.addEventListener('dragend',   onDragEnd);

    container.appendChild(div);
  });
}

/* ─── Drag & Drop Handlers ─── */
function onDragStart(e) {
  dragSrcIndex = parseInt(e.currentTarget.dataset.index);
  e.currentTarget.classList.add('dragging');
  e.dataTransfer.effectAllowed = 'move';
}
function onDragOver(e) {
  e.preventDefault();
  e.dataTransfer.dropEffect = 'move';
  document.querySelectorAll('.reorder-block').forEach(b => b.classList.remove('drag-over'));
  e.currentTarget.classList.add('drag-over');
}
function onDrop(e) {
  e.preventDefault();
  const destIndex = parseInt(e.currentTarget.dataset.index);
  if (dragSrcIndex === null || dragSrcIndex === destIndex) return;
  // Tausche in currentOrder
  const temp = currentOrder[dragSrcIndex];
  currentOrder[dragSrcIndex] = currentOrder[destIndex];
  currentOrder[destIndex] = temp;
  renderReorder();
}
function onDragEnd() {
  document.querySelectorAll('.reorder-block').forEach(b => {
    b.classList.remove('dragging', 'drag-over');
  });
  dragSrcIndex = null;
}

/* ─── Antwort prüfen – PHASE 1 ───────────────────
   Prüft Reihenfolge. Bei Erfolg: startet Wiedergabe.
   Bei Fehler: zeigt Fehlermeldung, bleibt interaktiv.
   ─────────────────────────────────────────────── */
function checkReorder() {
  const correct = currentOrder.every((origIdx, i) => origIdx === i);

  // Blöcke farblich markieren (richtig=grün, falsch=rot)
  const blocks = document.querySelectorAll('.reorder-block');
  currentOrder.forEach((origIdx, i) => {
    blocks[i].classList.remove('correct', 'wrong');
    blocks[i].classList.add(origIdx === i ? 'correct' : 'wrong');
  });

  if (correct) {
    appState.dialogCorrect = true;
    // Kurze Erfolgsrückmeldung, dann Wiedergabe starten
    showFeedback('4', 'success', '🎉 Perfekt! Die Reihenfolge ist richtig! Das Gespräch beginnt jetzt …');
    setTimeout(() => {
      hideFeedback('4');
      startDialoguePlayback();
    }, 1400);
  } else {
    appState.dialogCorrect = false;
    showFeedback('4', 'error', '❌ Noch nicht richtig. Schau dir die roten Blöcke an und versuche es noch einmal!');
  }
}

/* =============================================
   DIALOGUE PLAYBACK ENGINE – PHASE 2
   Runs ONLY after correct reorder submission.
   
   Steps:
   1. Hide the reorder panel + buttons
   2. Show the playback overlay
   3. Apply illness animation to playback patient
   4. Play each dialogue line with:
      - Speaker spotlight / dim
      - Animated speech bubble (pop + auto-hide)
      - Transcript line reveal
      - Correct delays
   5. Show success banner + continue button
   ============================================= */

/* Delay between each dialogue line (ms) */
const PB_LINE_DELAY    = 2200;   // time each bubble is shown
const PB_PAUSE_BETWEEN = 400;    // gap between lines

function startDialoguePlayback() {
  // ── 1. Hide reorder UI ──
  const reorderWrap = document.getElementById('reorder-panel-wrap');
  const reorderBtns = document.getElementById('reorder-btns');
  const vocabStrip  = document.querySelector('#scene-4 .vocab-strip');
  if (reorderWrap) reorderWrap.style.display = 'none';
  if (reorderBtns) reorderBtns.style.display = 'none';
  if (vocabStrip)  vocabStrip.style.display  = 'none';

  // ── 2. Show playback overlay ──
  const overlay = document.getElementById('playback-overlay');
  overlay.classList.add('active');

  // ── 3. Apply illness animation to playback patient ──
  applyPlaybackIllness(activeIllness.name);

  // ── 4. Build progress dots ──
  const lines = activeIllness.dialogue;
  const dotsEl = document.getElementById('pb-dots');
  dotsEl.innerHTML = lines.map((_, i) => `<div class="pb-dot" id="pb-dot-${i}"></div>`).join('');

  // Clear transcript
  const transcript = document.getElementById('pb-transcript');
  // Keep the title row, remove any lines from previous runs
  const existingLines = transcript.querySelectorAll('.pb-line');
  existingLines.forEach(l => l.remove());

  // ── 5. Play lines sequentially ──
  playLine(0, lines);
}

/* ─── Play one dialogue line, then recurse ─── */
function playLine(index, lines) {
  if (index >= lines.length) {
    // All lines done → show success banner
    endPlayback();
    return;
  }

  const line    = lines[index];
  const isDoctor = line.speaker === 'arzt';

  // Update progress dot
  const prevDot = document.getElementById(`pb-dot-${index - 1}`);
  if (prevDot) prevDot.classList.replace('active', 'done');
  const curDot = document.getElementById(`pb-dot-${index}`);
  if (curDot) curDot.classList.add('active');

  // Update cinematic top bar
  const labelEl = document.getElementById('pb-speaker-label');
  labelEl.textContent = isDoctor ? '👨‍⚕️ Arzt spricht …' : '🧑 Patient spricht …';

  // ── Spotlight / dim characters ──
  const drWrap = document.getElementById('pb-dr-wrap');
  const ptWrap = document.getElementById('pb-pt-wrap');
  drWrap.classList.remove('pb-speaking', 'pb-speaking-doctor', 'pb-dimmed');
  ptWrap.classList.remove('pb-speaking', 'pb-dimmed');

  if (isDoctor) {
    drWrap.classList.add('pb-speaking-doctor');
    ptWrap.classList.add('pb-dimmed');
    setPlaybackCharState('pb-dr-svg', 'speaking');
    setPlaybackCharState('pb-pt-svg', getIllnessClass(activeIllness.name));
  } else {
    ptWrap.classList.add('pb-speaking');
    drWrap.classList.add('pb-dimmed');
    setPlaybackCharState('pb-pt-svg', 'speaking');
    setPlaybackCharState('pb-dr-svg', 'idle');
  }

  // ── Show speech bubble ──
  const drBub = document.getElementById('pb-dr-bubble');
  const ptBub = document.getElementById('pb-pt-bubble');

  // Hide both first
  drBub.classList.remove('visible');
  ptBub.classList.remove('visible');
  drBub.textContent = '';
  ptBub.textContent = '';

  const activeBub = isDoctor ? drBub : ptBub;
  activeBub.textContent = line.text;
  // Trigger animation restart
  activeBub.style.animation = 'none';
  activeBub.offsetHeight;
  activeBub.style.animation = '';
  activeBub.classList.add('visible');

  // ── Add transcript line ──
  addTranscriptLine(line, index);

  // ── Scroll transcript to bottom ──
  const transcript = document.getElementById('pb-transcript');
  setTimeout(() => { transcript.scrollTop = transcript.scrollHeight; }, 100);

  // ── Schedule next line ──
  setTimeout(() => {
    // Fade out bubble before next line
    activeBub.classList.remove('visible');
    setPlaybackCharState(isDoctor ? 'pb-dr-svg' : 'pb-pt-svg', 'idle');
    setTimeout(() => playLine(index + 1, lines), PB_PAUSE_BETWEEN);
  }, PB_LINE_DELAY);
}

/* ─── Add a line to the transcript ─── */
function addTranscriptLine(line, index) {
  const transcript = document.getElementById('pb-transcript');
  const div = document.createElement('div');
  const isDoctor = line.speaker === 'arzt';
  div.className = `pb-line ${isDoctor ? 'pb-line-arzt' : 'pb-line-patient'}`;
  div.innerHTML = `
    <span class="pb-line-speaker">${isDoctor ? 'Arzt' : 'Patient'}</span>
    <span class="pb-line-text">${line.text}</span>
  `;
  transcript.appendChild(div);
  // Trigger reveal animation with small stagger
  setTimeout(() => div.classList.add('revealed'), 60);
}

/* ─── End of playback: show success banner + continue ─── */
function endPlayback() {
  // Mark last dot done
  const lines = activeIllness.dialogue;
  const lastDot = document.getElementById(`pb-dot-${lines.length - 1}`);
  if (lastDot) lastDot.classList.replace('active', 'done');

  // Update top bar
  const labelEl = document.getElementById('pb-speaker-label');
  labelEl.textContent = '✅ Gespräch beendet';

  // Both characters idle & full opacity
  const drWrap = document.getElementById('pb-dr-wrap');
  const ptWrap = document.getElementById('pb-pt-wrap');
  drWrap.classList.remove('pb-speaking', 'pb-speaking-doctor', 'pb-dimmed');
  ptWrap.classList.remove('pb-speaking', 'pb-dimmed');
  setPlaybackCharState('pb-dr-svg', 'idle');
  setPlaybackCharState('pb-pt-svg', 'idle');

  // Show success banner
  setTimeout(() => {
    document.getElementById('pb-success-banner').classList.add('active');
    setTimeout(() => document.getElementById('btn-continue-4').classList.remove('hidden'), 600);
  }, 500);
}

/* ─── Helper: set playback SVG animation state ─── */
function setPlaybackCharState(svgId, state) {
  const el = document.getElementById(svgId);
  if (!el) return;
  // Remove all state classes
  el.classList.remove('idle', 'speaking', 'anim-kopf', 'anim-bauch', 'anim-fieber', 'anim-husten');
  el.classList.add(state);
}

/* ─── Apply illness animation to playback patient ─── */
function applyPlaybackIllness(illnessName) {
  const ptSvg  = document.getElementById('pb-pt-svg');
  const sweat1 = document.getElementById('pb-sweat1');
  const sweat2 = document.getElementById('pb-sweat2');
  const mouth  = document.getElementById('pb-pt-mouth');
  if (!ptSvg) return;

  ptSvg.classList.remove('idle','speaking','anim-kopf','anim-bauch','anim-fieber','anim-husten');
  if (sweat1) sweat1.classList.add('hidden');
  if (sweat2) sweat2.classList.add('hidden');

  switch(illnessName) {
    case 'Kopfschmerzen':
      ptSvg.classList.add('anim-kopf');
      if (mouth) mouth.setAttribute('d', 'M26 43 Q33 39 40 43');
      break;
    case 'Bauchschmerzen':
      ptSvg.classList.add('anim-bauch');
      if (mouth) mouth.setAttribute('d', 'M26 43 Q33 40 40 43');
      break;
    case 'Fieber':
      ptSvg.classList.add('anim-fieber');
      if (sweat1) sweat1.classList.remove('hidden');
      if (sweat2) sweat2.classList.remove('hidden');
      if (mouth) mouth.setAttribute('d', 'M27 42 Q33 39 39 42');
      break;
    case 'Husten':
      ptSvg.classList.add('anim-husten');
      if (mouth) mouth.setAttribute('d', 'M26 42 Q33 46 40 42');
      break;
    default:
      ptSvg.classList.add('idle');
  }
}

/* ─── Return CSS animation class for illness (used while other char speaks) ─── */
function getIllnessClass(illnessName) {
  const map = {
    'Kopfschmerzen': 'anim-kopf',
    'Bauchschmerzen': 'anim-bauch',
    'Fieber': 'anim-fieber',
    'Husten': 'anim-husten',
  };
  return map[illnessName] || 'idle';
}

/* =============================================
   ABSCHLUSSBILDSCHIRM aufbauen
   ============================================= */
function buildFinalScreen() {
  const t1 = appState.scene1Time !== null ? `${appState.scene1Time}s` : '—';
  const t3 = appState.scene3Time !== null ? `${appState.scene3Time}s` : '—';
  const d4 = appState.dialogCorrect ? '✅ Richtig' : '❌ Falsch';

  document.getElementById('res-time1').textContent = t1;
  document.getElementById('res-time3').textContent = t3;
  document.getElementById('res-dialog').textContent = d4;

  // Gesamt-Feedback berechnen
  const totalTime = (appState.scene1Time || 0) + (appState.scene3Time || 0);
  let title, subtitle, trophy;

  if (appState.dialogCorrect && totalTime <= 30) {
    title    = 'Ausgezeichnet! 🌟';
    subtitle = 'Du hast alles richtig gemacht und sehr schnell gespielt!';
    trophy   = '🏆';
  } else if (appState.dialogCorrect) {
    title    = 'Gut gemacht! 👍';
    subtitle = `Du hast den Dialog richtig geordnet! Gesamtzeit: ${totalTime} Sekunden.`;
    trophy   = '🥇';
  } else {
    title    = 'Weiter üben!';
    subtitle = 'Der Dialog war nicht ganz richtig. Versuche es noch einmal!';
    trophy   = '💪';
  }

  document.getElementById('final-title').textContent    = title;
  document.getElementById('final-subtitle').textContent = subtitle;
  document.getElementById('final-trophy').textContent   = trophy;
}

/* =============================================
   APP START – Titelbildschirm ist per CSS aktiv
   ============================================= */
</script>
