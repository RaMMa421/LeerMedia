<script>
/* =============================================
   GLOBALER ZUSTAND
   Speichert Szenenfortschritt, Zeiten, Ergebnisse
   ============================================= */
const appState = {
  scene1Time: null,   // Sekunden für Szene 1
  scene3Time: null,   // Sekunden für Szene 3
  dialogCorrect: false,
  dialogue2Done: false,
  currentIllness: null, // zufällig gewählte Krankheit
};

/* =============================================
   FORTSCHRITTSBALKEN
   ============================================= */
function renderProgress(active) {
  const steps = [
    { num: 1, label: 'Rezeption' },
    { num: 2, label: 'Dialog' },
    { num: 3, label: 'Arzt' },
    { num: 4, label: 'Gespräch' },
  ];
  const el = document.getElementById(`progress-${active}`);
  if (!el) return;
  el.innerHTML = steps.map((s, i) => `
    <div class="progress-step ${s.num < active ? 'done' : s.num === active ? 'active' : ''}">
      <div class="step-dot">${s.num < active ? '✓' : s.num}</div>
      <span>${s.label}</span>
    </div>
    ${i < steps.length - 1 ? `<div class="progress-line ${s.num < active ? 'done' : ''}"></div>` : ''}
  `).join('');
}

/* =============================================
   SZENENNAVIGATION
   ============================================= */
function goScene(name) {
  document.querySelectorAll('.scene').forEach(s => s.classList.remove('active'));
  if (name === 'final') {
    buildFinalScreen();
    document.getElementById('scene-final').classList.add('active');
    return;
  }
  const el = document.getElementById(`scene-${name}`);
  if (el) el.classList.add('active');
  if (name === 1) { renderProgress(1); initGrid(1); }
  if (name === 2) { renderProgress(2); initScene2(); }
  if (name === 3) { renderProgress(3); initGrid(3); }
  if (name === 4) { renderProgress(4); initReorder(); }
}

function startApp() { goScene(1); }

function restartApp() {
  // Alles zurücksetzen
  appState.scene1Time = null;
  appState.scene3Time = null;
  appState.dialogCorrect = false;
  appState.dialogue2Done = false;
  appState.currentIllness = null;
  goScene('title');
  document.querySelectorAll('.scene').forEach(s => s.classList.remove('active'));
  document.getElementById('scene-title').classList.add('active');
}

/* =============================================
   FEEDBACK-HELFER
   ============================================= */
function showFeedback(id, type, msg) {
  const el = document.getElementById(`feedback-${id}`);
  if (!el) return;
  el.className = `feedback ${type}`;
  el.textContent = msg;
  el.classList.remove('hidden');
}
function hideFeedback(id) {
  const el = document.getElementById(`feedback-${id}`);
  if (el) el.classList.add('hidden');
}

/* =============================================
   ==========================================
   KARTEN-SYSTEM – 4×4 FESTES GITTER
   
   DESIGN-PRINZIPIEN:
   - Feste 4×4 Größe (immer)
   - Mindestens 3 Richtungswechsel nötig
   - Hindernisse blockieren Abkürzungen
   - Mehrere kuratierte Layouts pro Schwierigkeitsstufe
   - Zufällige Auswahl beim Start → Wiederholbarkeit
   
   Jedes Layout definiert:
     map:   4×4-Array (' '=frei, 'X'=Hindernis)
     start: { row, col } – immer links
     goal:  { row, col } – immer rechts
     hint:  kurze Beschreibung der Pflichtbewegungen
   ==========================================
   ============================================= */

/*
  Richtungs-Kodierung:
  0 = oben    (up)
  1 = rechts  (right)
  2 = unten   (down)
  3 = links   (left)
*/
const DIR_VECTORS = [
  { dr: -1, dc:  0 }, // 0: oben
  { dr:  0, dc:  1 }, // 1: rechts
  { dr:  1, dc:  0 }, // 2: unten
  { dr:  0, dc: -1 }, // 3: links
];
const DIR_EMOJIS = ['⬆️','➡️','⬇️','⬅️'];

/* Zufallszahl zwischen min und max (inklusiv) */
function randInt(min, max) {
  return Math.floor(Math.random() * (max - min + 1)) + min;
}

/* ─────────────────────────────────────────────
   KURATIERTE LAYOUTS – SZENE 1 (schwieriger)
   Jeder Weg benötigt mindestens 3 Abbiegungen.
   X = Hindernis (Pflanze / Patient)
   S = Start  (immer Spalte 0)
   G = Ziel   (immer Spalte 3)
   
   Karten sind als Strings kodiert:
   Zeilen durch '|' getrennt, 4 Zeichen pro Zeile
   ' ' = frei, 'X' = Hindernis
   ───────────────────────────────────────────── */
const LAYOUTS_SCENE1 = [
  {
    // Weg: → ↓ → ↑ → (Zickzack durch Mitte)
    // Start: Zeile 0, Ziel: Zeile 0 Spalte 3 – aber direkte Linie blockiert
    rows: [
      [' ','X',' ','X'],  // Reihe 0
      [' ',' ','X',' '],  // Reihe 1 – Tunnel
      ['X',' ',' ',' '],  // Reihe 2
      [' ','X',' ','X'],  // Reihe 3
    ],
    start: { row: 0, col: 0 },
    goal:  { row: 2, col: 3 },
    // Kürzester Weg: →↓→↓→ (3 Abbiegungen)
  },
  {
    // Zickzack von links nach rechts, mit Blockaden in jeder Gasse
    rows: [
      [' ',' ','X',' '],
      ['X','X',' ','X'],
      [' ',' ',' ','X'],
      ['X',' ','X',' '],
    ],
    start: { row: 0, col: 0 },
    goal:  { row: 3, col: 3 },
    // Weg: ↓↓ →→ ↑↑ →→ (4 Abbiegungen)
  },
  {
    // Spiralartiger Weg – blockierte Ecken erzwingen Umweg
    rows: [
      [' ','X',' ',' '],
      [' ','X','X',' '],
      [' ',' ','X',' '],
      ['X',' ',' ',' '],
    ],
    start: { row: 0, col: 0 },
    goal:  { row: 0, col: 3 },
    // Direkte Linie blockiert → Umweg nach unten nötig
  },
  {
    // Doppelte Barriere in der Mitte
    rows: [
      [' ',' ','X',' '],
      ['X',' ','X',' '],
      [' ',' ',' ','X'],
      [' ','X',' ',' '],
    ],
    start: { row: 2, col: 0 },
    goal:  { row: 0, col: 3 },
    // Muss nach oben, rechts, hoch, rechts (4 Abbiegungen)
  },
  {
    // Schlangenförmig
    rows: [
      [' ',' ',' ','X'],
      ['X','X',' ','X'],
      [' ',' ',' ',' '],
      [' ','X','X','X'],
    ],
    start: { row: 0, col: 0 },
    goal:  { row: 2, col: 3 },
  },
  {
    // Eckblocker – verhindert Randabkürzung
    rows: [
      ['X',' ','X',' '],
      [' ',' ','X',' '],
      [' ','X',' ',' '],
      [' ',' ',' ','X'],
    ],
    start: { row: 1, col: 0 },
    goal:  { row: 2, col: 3 },
  },
];

/* ─────────────────────────────────────────────
   KURATIERTE LAYOUTS – SZENE 3 (etwas einfacher,
   aber immer noch mind. 3 Abbiegungen nötig)
   ───────────────────────────────────────────── */
const LAYOUTS_SCENE3 = [
  {
    // Einfacherer Zickzack
    rows: [
      [' ',' ','X',' '],
      ['X',' ',' ','X'],
      [' ','X',' ',' '],
      [' ',' ','X',' '],
    ],
    start: { row: 0, col: 0 },
    goal:  { row: 1, col: 3 },
  },
  {
    // Zwei Hindernisreihen
    rows: [
      [' ','X',' ',' '],
      [' ',' ','X',' '],
      ['X',' ',' ','X'],
      [' ',' ',' ',' '],
    ],
    start: { row: 3, col: 0 },
    goal:  { row: 0, col: 3 },
  },
  {
    // Diagonale Blockade
    rows: [
      [' ',' ',' ','X'],
      [' ','X',' ',' '],
      ['X',' ',' ',' '],
      [' ',' ','X',' '],
    ],
    start: { row: 0, col: 0 },
    goal:  { row: 3, col: 3 },
  },
  {
    rows: [
      [' ','X',' ',' '],
      [' ',' ','X',' '],
      ['X',' ',' ','X'],
      [' ',' ',' ',' '],
    ],
    start: { row: 0, col: 0 },
    goal:  { row: 2, col: 2 },
  },
];

/* ─────────────────────────────────────────────
   BFS-PFADVALIDIERUNG
   Prüft, ob Start → Ziel erreichbar ist.
   Gibt true zurück wenn ein Weg existiert.
   ───────────────────────────────────────────── */
function isSolvable(map, start, goal) {
  const rows = map.length, cols = map[0].length;
  const visited = Array.from({ length: rows }, () => Array(cols).fill(false));
  const queue = [{ r: start.row, c: start.col }];
  visited[start.row][start.col] = true;

  while (queue.length > 0) {
    const { r, c } = queue.shift();
    if (r === goal.row && c === goal.col) return true;
    for (const { dr, dc } of DIR_VECTORS) {
      const nr = r + dr, nc = c + dc;
      if (nr >= 0 && nr < rows && nc >= 0 && nc < cols && !visited[nr][nc] && map[nr][nc] !== 'X') {
        visited[nr][nc] = true;
        queue.push({ r: nr, c: nc });
      }
    }
  }
  return false;
}

/* ─────────────────────────────────────────────
   LAYOUT AUSWÄHLEN
   Wählt ein zufälliges Layout aus dem Pool und
   prüft Lösbarkeit. Fällt auf erstes Layout zurück.
   ───────────────────────────────────────────── */
function pickLayout(sceneNum) {
  const pool = sceneNum === 1 ? LAYOUTS_SCENE1 : LAYOUTS_SCENE3;
  // Zufällige Auswahl aus dem Pool
  const shuffled = [...pool].sort(() => Math.random() - 0.5);
  for (const layout of shuffled) {
    if (isSolvable(layout.rows, layout.start, layout.goal)) {
      return { map: layout.rows.map(r => [...r]), start: layout.start, goal: layout.goal };
    }
  }
  // Fallback: erstes lösbares Layout
  return { map: pool[0].rows.map(r => [...r]), start: pool[0].start, goal: pool[0].goal };
}

/* ─── Pro-Grid-Zustand ─── */
const gridData = {
  1: { map: null, start: null, goal: null, startDir: 1, commands: [], charRow: 0, charCol: 0, charDir: 1, running: false, timerStart: null, timerInterval: null },
  3: { map: null, start: null, goal: null, startDir: 1, commands: [], charRow: 0, charCol: 0, charDir: 1, running: false, timerStart: null, timerInterval: null },
};

/* ─── Grid initialisieren (kuratiertes 4×4-Layout) ─── */
function initGrid(sceneNum) {
  const gd = gridData[sceneNum];

  // Wähle ein zufälliges Layout aus dem kuratierten Pool
  // Immer 4×4, mindestens 3 Richtungswechsel nötig
  const layout = pickLayout(sceneNum);

  gd.map      = layout.map;
  gd.start    = layout.start;
  gd.goal     = layout.goal;
  gd.startDir = 1;            // Charakter zeigt immer zuerst nach rechts
  gd.charRow  = layout.start.row;
  gd.charCol  = layout.start.col;
  gd.charDir  = 1;
  gd.commands = [];
  gd.running  = false;

  stopTimer(sceneNum);
  renderSequence(sceneNum);
  renderGrid(sceneNum);
  hideFeedback(sceneNum);
  updateCompass(sceneNum);
}

/* ─── Grid zeichnen ─── */
function renderGrid(sceneNum) {
  const gd   = gridData[sceneNum];
  const el   = document.getElementById(`grid${sceneNum}`);
  const cols = gd.map[0].length; // immer 4

  // Festes 4×4 Raster mit 64px Zellen
  el.style.gridTemplateColumns = `repeat(${cols}, 64px)`;
  el.innerHTML = '';

  gd.map.forEach((row, r) => {
    row.forEach((cell, c) => {
      const div = document.createElement('div');
      div.className = 'cell';
      div.id = `cell-${sceneNum}-${r}-${c}`;

      if (cell === 'X') {
        div.classList.add('obstacle');
        // Abwechselnd Pflanze und Patient als Hindernis-Emoji
        div.textContent = ((r + c) % 2 === 0) ? '🌿' : '🧑';
      } else if (r === gd.goal.row && c === gd.goal.col) {
        div.classList.add('goal-cell');
        div.textContent = sceneNum === 1 ? '🏥' : '🩺';
      } else if (r === gd.start.row && c === gd.start.col) {
        div.classList.add('start-cell');
        // Zeige Startmarkierung nur wenn Charakter woanders ist
        if (r !== gd.charRow || c !== gd.charCol) div.textContent = '🚩';
      }

      // Charakter auf dieser Zelle zeichnen
      if (r === gd.charRow && c === gd.charCol) {
        div.innerHTML = '';
        const char = document.createElement('div');
        char.className = 'character';
        char.textContent = DIR_EMOJIS[gd.charDir];
        div.appendChild(char);
        div.style.position = 'relative';
      }

      el.appendChild(div);
    });
  });
}

/* ─── Kompass-Anzeige aktualisieren ─── */
function updateCompass(sceneNum) {
  const el = document.getElementById(`dir${sceneNum}-display`);
  if (el) el.textContent = DIR_EMOJIS[gridData[sceneNum].charDir];
}

/* ─── Timer-Funktionen ─── */
function startTimer(sceneNum) {
  const gd = gridData[sceneNum];
  if (gd.timerInterval) return; // läuft schon
  gd.timerStart = Date.now();
  gd.timerInterval = setInterval(() => {
    const secs = Math.floor((Date.now() - gd.timerStart) / 1000);
    const el = document.getElementById(`timer${sceneNum}-display`);
    if (el) el.textContent = `${secs}s`;
  }, 500);
}

function stopTimer(sceneNum) {
  const gd = gridData[sceneNum];
  if (gd.timerInterval) {
    clearInterval(gd.timerInterval);
    gd.timerInterval = null;
  }
}

function getElapsedSeconds(sceneNum) {
  const gd = gridData[sceneNum];
  if (!gd.timerStart) return 0;
  return Math.floor((Date.now() - gd.timerStart) / 1000);
}

/* ─── Befehl hinzufügen ─── */
function addCommand(sceneNum, cmd) {
  const gd = gridData[sceneNum];
  if (gd.running) return;
  gd.commands.push(cmd);
  // Timer beim ersten Befehl starten
  if (gd.commands.length === 1) startTimer(sceneNum);
  renderSequence(sceneNum);
}

/* ─── Befehlsliste leeren ─── */
function clearCommands(sceneNum) {
  const gd = gridData[sceneNum];
  if (gd.running) return;
  gd.commands = [];
  renderSequence(sceneNum);
}

/* ─── Szene zurücksetzen (neue Karte generieren) ─── */
function resetScene(sceneNum) {
  stopTimer(sceneNum);
  initGrid(sceneNum);
}

/* ─── Befehlssequenz anzeigen ─── */
function renderSequence(sceneNum) {
  const el  = document.getElementById(`seq-${sceneNum}`);
  const cmd = gridData[sceneNum].commands;
  const icons  = { forward: '⬆', left: '↰', right: '↱' };
  const labels = { forward: 'Vor', left: 'Links', right: 'Rechts' };
  const classes = { forward: 'forward', left: 'turnleft', right: 'turnright' };

  el.innerHTML = cmd.length === 0
    ? '<span style="color:var(--text-light);font-size:0.8rem;font-weight:600;padding:4px;">Füge Befehle hinzu…</span>'
    : cmd.map((c, i) => `
        <div class="seq-item ${classes[c]}">
          <span style="opacity:0.6;font-size:0.72rem;">${i+1}</span>
          ${icons[c]} ${labels[c]}
        </div>`).join('');
}

/* ─── Befehle ausführen (animiert) ─── */
function runCommands(sceneNum) {
  const gd   = gridData[sceneNum];
  if (gd.running) return;
  if (gd.commands.length === 0) {
    showFeedback(sceneNum, 'info', 'ℹ️ Füge zuerst Befehle hinzu!');
    return;
  }

  hideFeedback(sceneNum);
  gd.running = true;
  document.getElementById(`run-btn-${sceneNum}`).disabled = true;

  // Position zurücksetzen
  let r   = gd.start.row;
  let c   = gd.start.col;
  let dir = gd.startDir;

  // Simuliere alle Schritte und erkenne Fehler
  const steps = [];
  let crashMsg = null;

  for (let i = 0; i < gd.commands.length; i++) {
    const cmd = gd.commands[i];
    if (cmd === 'left')  dir = (dir + 3) % 4;
    if (cmd === 'right') dir = (dir + 1) % 4;
    if (cmd === 'forward') {
      const nr = r + DIR_VECTORS[dir].dr;
      const nc = c + DIR_VECTORS[dir].dc;
      if (nr < 0 || nr >= gd.map.length || nc < 0 || nc >= gd.map[0].length) {
        crashMsg = '🚧 Außerhalb des Weges! Versuche es erneut.';
        break;
      }
      if (gd.map[nr][nc] === 'X') {
        crashMsg = '🌿 Hindernis! Da ist etwas im Weg. Versuche es erneut.';
        break;
      }
      r = nr; c = nc;
    }
    steps.push({ r, c, dir, crashed: false });
  }
  if (crashMsg) steps.push({ r, c, dir, crashed: true, msg: crashMsg });

  // Animation Schritt für Schritt
  let idx = 0;
  function nextStep() {
    if (idx >= steps.length) {
      // Animation fertig
      gd.charRow = r;
      gd.charCol = c;
      gd.charDir = dir;
      renderGrid(sceneNum);
      updateCompass(sceneNum);
      gd.running = false;
      document.getElementById(`run-btn-${sceneNum}`).disabled = false;

      if (crashMsg) {
        showFeedback(sceneNum, 'error', crashMsg);
      } else if (r === gd.goal.row && c === gd.goal.col) {
        // 🎉 Erfolg!
        stopTimer(sceneNum);
        const elapsed = getElapsedSeconds(sceneNum);
        if (sceneNum === 1) appState.scene1Time = elapsed;
        if (sceneNum === 3) appState.scene3Time = elapsed;
        showFeedback(sceneNum, 'success',
          sceneNum === 1
            ? `🎉 Bravo! Du hast die Rezeption erreicht! Zeit: ${elapsed} Sekunden`
            : `🎉 Wunderbar! Du bist beim Arzt! Zeit: ${elapsed} Sekunden`
        );
        setTimeout(() => goScene(sceneNum + 1), 2000);
      } else {
        showFeedback(sceneNum, 'error', '❌ Falscher Weg! Das Ziel wurde nicht erreicht. Versuche es erneut.');
      }
      return;
    }

    const s = steps[idx++];
    gd.charRow = s.r;
    gd.charCol = s.c;
    gd.charDir = s.dir;
    renderGrid(sceneNum);
    updateCompass(sceneNum);

    // Besuchte Zelle markieren
    const cellEl = document.getElementById(`cell-${sceneNum}-${s.r}-${s.c}`);
    if (cellEl && !cellEl.classList.contains('goal-cell')) {
      cellEl.classList.add('path-visited');
    }
    setTimeout(nextStep, 380);
  }

  renderGrid(sceneNum);
  setTimeout(nextStep, 300);
}

/* =============================================
   SZENE 2: REZEPTIONSDIALOG – ANIMATIONSLOGIK
   ============================================= */
function initScene2() {
